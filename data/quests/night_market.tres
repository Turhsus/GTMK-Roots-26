[ext_resource type="Script" uid="uid://3jm4762kubo8" path="res://resources/narrative_line.gd" id="13_line"]
[ext_resource type="Script" uid="uid://45ajj2ptcv0d" path="res://resources/narrative_event.gd" id="14_event"]

[sub_resource type="Resource" id="line_arrive_light"]
script = ExtResource("13_line")
text = "The market only opens after dark, down the lane where the lamps run out. They held their own little light up like a ticket, and every stall leaned toward them to be seen."
require_tags = Array[String](["light"])

[sub_resource type="Resource" id="line_arrive_dark"]
script = ExtResource("13_line")
text = "The market only opens after dark, down the lane where the lamps run out. With nothing to see by, they went slow and kept one hand on the wall, and the stalls stayed shy of them."

[sub_resource type="Resource" id="event_arrival"]
script = ExtResource("14_event")
beat_id = "arrival"
variants = Array[ExtResource("13_line")]([SubResource("line_arrive_light"), SubResource("line_arrive_dark")])

[sub_resource type="Resource" id="line_supper_full"]
script = ExtResource("13_line")
text = "They traded a button for a bowl of something spiced and ate it on the kerb with their heels drumming, and had enough left to buy a sugared plum for the walk home."
require_stat = {
"food": 6
}

[sub_resource type="Resource" id="line_supper_some"]
script = ExtResource("13_line")
text = "They had a little to eat and made it last, splitting a roll into careful halves and telling themselves the second half was for later."
require_tags = Array[String](["food"])

[sub_resource type="Resource" id="line_supper_none"]
script = ExtResource("13_line")
text = "Everything smelled wonderful and nothing was theirs to eat. They watched other people's suppers and pretended the smell was almost the same as a meal."

[sub_resource type="Resource" id="event_supper"]
script = ExtResource("14_event")
beat_id = "supper"
variants = Array[ExtResource("13_line")]([SubResource("line_supper_full"), SubResource("line_supper_some"), SubResource("line_supper_none")])

[resource]
script = ExtResource("1_script")
id = "night_market"
title = "The Night Market"
brief = "There's a market that only opens after dark at the edge of town.
It's just one evening out — pack light, but pack something to eat."
days = 2
gold_reward = 15
bag_cols = 5
bag_rows = 4
item_pool = Array[ExtResource("2_item")]([ExtResource("4_bread"), ExtResource("3_apple"), ExtResource("5_waterskin"), ExtResource("6_cookpot"), ExtResource("7_blanket"), ExtResource("8_lantern"), ExtResource("9_whistle"), ExtResource("10_potion"), ExtResource("11_boots"), ExtResource("12_map")])
narrative = Array[ExtResource("14_event")]([SubResource("event_arrival"), SubResource("event_supper")])
target_food = 6
target_health = 2
target_combat = 0
target_utility = 0
