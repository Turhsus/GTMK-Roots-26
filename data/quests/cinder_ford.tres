[ext_resource type="Script" uid="uid://45ajj2ptcv0d" path="res://resources/narrative_event.gd" id="14_event"]

[sub_resource type="Resource" id="line_cross_braced"]
script = ExtResource("13_line")
text = "The ford runs fast and grey over black stones. They set their shoulder behind what they were carrying, leaned into the current, and crossed it a careful step at a time without ever going under."
require_stat = {
"defense": 5
}

[sub_resource type="Resource" id="line_cross_roped"]
script = ExtResource("13_line")
text = "The ford runs fast and grey over black stones. They tied a line to the leaning willow and went hand over hand across it, feet skating, and hauled themselves out on the far side soaked to the ribs but grinning."
require_tags = Array[String](["climbing"])

[sub_resource type="Resource" id="line_cross_swept"]
script = ExtResource("13_line")
text = "The ford runs fast and grey over black stones. They picked the wrong one halfway across, went in to the waist, and came up spitting river a good way downstream with both shoes still on, thankfully."

[sub_resource type="Resource" id="event_crossing"]
script = ExtResource("14_event")
beat_id = "crossing"
variants = Array[ExtResource("13_line")]([SubResource("line_cross_braced"), SubResource("line_cross_roped"), SubResource("line_cross_swept")])

[sub_resource type="Resource" id="line_bank_healed"]
script = ExtResource("13_line")
text = "On the far bank they found a long scrape earned on the black stones, dabbed it with what you packed for exactly this, and were back on their feet before the light had moved."
require_tags = Array[String](["healing"])

[sub_resource type="Resource" id="line_bank_warm"]
script = ExtResource("13_line")
text = "On the far bank they wrung themselves out, got a small flame going, and sat close to it turning like a chicken on a spit until the shivering stopped."
require_tags = Array[String](["light"])

[sub_resource type="Resource" id="line_bank_cold"]
script = ExtResource("13_line")
text = "On the far bank there was nothing to do but keep walking to stay warm, wet through, teeth going like a little drum, proud and miserable in equal parts."

[sub_resource type="Resource" id="event_far_bank"]
script = ExtResource("14_event")
beat_id = "far_bank"
variants = Array[ExtResource("13_line")]([SubResource("line_bank_healed"), SubResource("line_bank_warm"), SubResource("line_bank_cold")])

[resource]
script = ExtResource("1_script")
id = "cinder_ford"
difficulty = 0
title = "Cross the Cinder Ford"
brief = "The quickest way to Gran's is straight across the Cinder Ford,
and the river's up. Pack them something to lean on when the water pushes back."
bag_cols = 6
bag_rows = 4
item_pool = Array[ExtResource("2_item")]([ExtResource("3_shield"), ExtResource("4_sword"), ExtResource("5_slingshot"), ExtResource("6_spellbook"), ExtResource("7_boots"), ExtResource("8_rope"), ExtResource("9_potion"), ExtResource("10_bread"), ExtResource("11_waterskin"), ExtResource("12_torch")])
narrative = Array[ExtResource("14_event")]([SubResource("event_crossing"), SubResource("event_far_bank")])
target_food = 0
target_health = 2
target_attack = 3
target_defense = 5
