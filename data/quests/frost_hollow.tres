[sub_resource type="Resource" id="line_night_warm"]
script = ExtResource("8_line")
text = "The cold came down off the hollow the moment the sun left. They pulled the blanket tight around their shoulders and dug in for the night, and the dark could not get a hand under it."
require_tags = Array[String](["comfort"])

[sub_resource type="Resource" id="line_night_cold"]
script = ExtResource("8_line")
text = "The cold came down off the hollow the moment the sun left. They had nothing to wrap up in, so they sat with their knees to their chest and counted the hours until grey light, shivering the whole way through."

[sub_resource type="Resource" id="event_night"]
script = ExtResource("9_event")
beat_id = "night"
variants = Array[ExtResource("8_line")]([SubResource("line_night_warm"), SubResource("line_night_cold")])

[resource]
script = ExtResource("1_script")
id = "frost_hollow"
title = "The Frost Hollow"
brief = "The path cuts through the frost hollow, and the sun leaves early up there.
It's only a night away — but the nights bite, so send them off ready for the cold."
difficulty = 0
days = 3
gold_reward = 25
bag_cols = 6
bag_rows = 4
item_pool = Array[ExtResource("2_item")]([ExtResource("3_blanket"), ExtResource("4_bread"), ExtResource("5_waterskin"), ExtResource("6_potion"), ExtResource("7_torch")])
required_items = Array[ExtResource("2_item")]([ExtResource("3_blanket")])
narrative = Array[ExtResource("9_event")]([SubResource("event_night")])
target_food = 4
target_health = 4
target_attack = 0
target_defense = 0
